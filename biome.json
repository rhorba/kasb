{
  "$schema": "https://biomejs.dev/schemas/1.9.4/schema.json",
  "organizeImports": {
    "enabled": true
  },
  "linter": {
    "enabled": true,
    "rules": {
      "recommended": true,
      "correctness": {
        "noUnusedImports": "error",
        "noUnusedVariables": "error"
      },
      "style": {
        "useImportType": "error"
      }
    }
  },
  "formatter": {
    "enabled": true,
    "indentStyle": "space",
    "indentWidth": 2,
    "lineWidth": 100
  },
  "javascript": {
    "formatter": {
      "quoteStyle": "double",
      "trailingCommas": "all",
      "semicolons": "always"
    }
  },
  "files": {
    "ignore": [
      "**/node_modules",
      "**/.next",
      "**/dist",
      "**/.turbo",
      "**/drizzle/*.sql",
      "apps/web/next-env.d.ts",
      "apps/web/public/sw.js",
      "apps/web/public/sw.js.map",
      "apps/web/public/workbox-*.js",
      "apps/web/public/swe-worker-*.js",
      "apps/web/public/worker-*.js",
      "apps/web/public/fallback-*.js"
    ]
  }
}
